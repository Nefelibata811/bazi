{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "bazi Web (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--no-web-resources-cdn",
        "--dart-define-from-file=.dart_defines.generated.json"
      ],
      "preLaunchTask": "bazi: sync dart defines"
    },
    {
      "name": "bazi Android (模拟器)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "android",
      "toolArgs": [
        "--no-enable-impeller",
        "--enable-software-rendering",
        "--dart-define-from-file=.dart_defines.generated.json"
      ],
      "preLaunchTask": "bazi: sync dart defines"
    },
    {
      "name": "bazi Windows 桌面",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "windows",
      "toolArgs": [
        "--dart-define-from-file=.dart_defines.generated.json"
      ],
      "preLaunchTask": "bazi: sync dart defines"
    }
  ]
}
