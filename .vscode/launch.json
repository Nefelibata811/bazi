{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "bazi Web (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--no-web-resources-cdn",
        "--dart-define-from-file=secrets.local.env"
      ]
    },
    {
      "name": "bazi Windows 桌面",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "windows",
      "toolArgs": ["--dart-define-from-file=secrets.local.env"]
    }
  ]
}
